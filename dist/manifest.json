{
  "manifest_version": 3,
  "name": "Webflow Class Guard",
  "version": "0.1.0",
  "description": "Protect Webflow utility classes from accidental edits in the Designer.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.design.webflow.com/*",
    "https://webflow.com/design/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-DZGFSBVI.js"
      ],
      "matches": [
        "https://*.design.webflow.com/*",
        "https://webflow.com/design/*"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/index-ByrcCeKv.css"
      ]
    }
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://*.design.webflow.com/*",
        "https://webflow.com/*"
      ],
      "resources": [
        "assets/storage-eG-FnA_d.js",
        "assets/index.ts-BpDuC3ig.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
